# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Optional: OpenAI model for improvement chat (clarify / scope / explore). Default: gpt-4.1
# OPENAI_ITERATE_MODEL=gpt-4o
DEFAULT_AI_PROVIDER=claude
MAX_FIX_ATTEMPTS=5
DAILY_ITERATION_LIMIT=10

# Database
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=appdb
DATABASE_URL=postgresql://appuser:apppassword@postgres:5432/appdb

# Auth
JWT_SECRET=change_me_in_production_use_long_random_string

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PROJECT=price_...   # one-time $150 price ID
STRIPE_PRICE_HOSTING=price_...   # recurring $20/month price ID
STRIPE_SUCCESS_URL=http://localhost
STRIPE_CANCEL_URL=http://localhost

# Services
GENERATED_APPS_DIR=/generated-apps
APP_RUNNER_URL=http://app-runner:4001
# Custom domain CNAME target: visitors CNAME www → <projectId>.HOSTING_SITES_HOST (match Caddy wildcard block)
HOSTING_SITES_HOST=sites.projectmaker.com

# Caddy — Cloudflare API token for DNS-01 challenge (wildcard cert for *.sites.projectmaker.com)
# Create at: Cloudflare Dashboard > My Profile > API Tokens — needs Zone:DNS:Edit permission
CF_API_TOKEN=your_cloudflare_api_token_here

# Base URLs (use HTTPS in production)
APP_BASE_URL=https://projectmaker.com
STRIPE_SUCCESS_URL=https://projectmaker.com/billing?success=true
STRIPE_CANCEL_URL=https://projectmaker.com/pricing

# Frontend (Vite public vars)
VITE_API_BASE_URL=https://projectmaker.com/api
