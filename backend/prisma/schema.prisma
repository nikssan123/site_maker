generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  stripeCustomerId String?   @unique
  freeProjectUsed  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  sessions         Session[]
}

model Session {
  id                   String              @id @default(uuid())
  userId               String
  user                 User                @relation(fields: [userId], references: [id])
  status               String              @default("planning") // "planning" | "generating" | "running" | "error"
  generationPurchased  Boolean             @default(false)
  createdAt            DateTime            @default(now())
  plan                 Plan?
  project              Project?
  messages             Message[]
  generationEvents     GenerationEvent[]
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
}

model Plan {
  id        String   @id @default(uuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id])
  data      Json
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id                    String         @id @default(uuid())
  sessionId             String         @unique
  session               Session        @relation(fields: [sessionId], references: [id])
  files                 Json           // { [path: string]: string }
  buildLog              String?
  errorLog              String?
  fixAttempts           Int            @default(0)
  runPort               Int?
  status                String         @default("generating") // "generating" | "building" | "running" | "error"
  paid                  Boolean        @default(false)
  hosted                Boolean        @default(false)
  hostingSubscriptionId String?        @unique
  customDomain              String?   @unique // BYO hostname e.g. www.brand.com
  customDomainVerifiedAt    DateTime?
  domainVerificationToken   String?
  paidIterationCredits  Int            @default(0)
  stripeAccountId       String?        // connected Stripe account via Standard Connect OAuth
  paymentsEnabled       Boolean        @default(false)
  buildEnv              Json?          // { VITE_STRIPE_PUBLISHABLE_KEY: "pk_..." } — baked into build at compile time
  runtimeEnv            String?        // AES-256-GCM encrypted JSON: { STRIPE_SECRET_KEY: "sk_..." } — injected into process env only
  analyticsEvents       AnalyticsPageView[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  iterationLogs         IterationLog[]
}

model IterationLog {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model GenerationEvent {
  id        Int      @id @default(autoincrement())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  payload   Json
  createdAt DateTime @default(now())

  @@index([sessionId, id])
}

model AnalyticsPageView {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path      String   @default("/")
  device    String   @default("desktop")
  referrer  String?
  visitorId String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}
