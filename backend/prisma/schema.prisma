generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                 @id @default(uuid())
  email            String                 @unique
  passwordHash     String
  isAdmin          Boolean                @default(false)
  stripeCustomerId String?                @unique
  freeProjectUsed  Boolean                @default(false)
  createdAt        DateTime               @default(now())
  sessions         Session[]
  emailChange      PendingEmailChange?
  passwordChange   PendingPasswordChange?

  // Iteration improvement plan (€20/mo subscription)
  iterationSubStripeId           String?   @unique
  iterationSubStatus             String? // "active" | "past_due" | "canceled" | null
  iterationSubCancelAtPeriodEnd  Boolean   @default(false)
  iterationSubCurrentPeriodStart DateTime?
  iterationSubCurrentPeriodEnd   DateTime?

  tokenUsage  TokenUsageLog[]
  tokenGrants TokenGrant[]
}

model PendingEmailChange {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model PendingPasswordChange {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newPasswordHash String
  codeHash        String
  attempts        Int      @default(0)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
}

model PendingRegistration {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  codeHash     String
  attempts     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([expiresAt])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Session {
  id                        String            @id @default(uuid())
  userId                    String
  user                      User              @relation(fields: [userId], references: [id])
  status                    String            @default("planning") // "planning" | "generating" | "running" | "error"
  generationPurchased       Boolean           @default(false)
  /// Set when €150 pre-generation checkout completes; consumed when first Project row is created for this session.
  sitePurchaseExtrasPending Boolean           @default(false)
  createdAt                 DateTime          @default(now())
  plan                      Plan?
  project                   Project?
  messages                  Message[]
  generationEvents          GenerationEvent[]
  planExecutions            PlanExecution[]
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
}

model Plan {
  id        String   @id @default(uuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id])
  data      Json
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())

  executions PlanExecution[]
}

model PlanExecution {
  id        String  @id @default(uuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  planId   String?
  plan     Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  planData Json

  /// Mirrors the generate request decision (free/paid/retry)
  projectPaid Boolean @default(false)
  isRetry     Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([planId, createdAt])
}

model Project {
  id                         String              @id @default(uuid())
  sessionId                  String              @unique
  session                    Session             @relation(fields: [sessionId], references: [id])
  files                      Json // { [path: string]: string }
  buildLog                   String?
  errorLog                   String?
  fixAttempts                Int                 @default(0)
  runPort                    Int?
  status                     String              @default("generating") // "generating" | "building" | "running" | "error"
  paid                       Boolean             @default(false)
  hosted                     Boolean             @default(false)
  /// Free hosting window (e.g. 1 month after €150 site purchase) when there is no Stripe subscription yet.
  hostingFreeUntil           DateTime?
  hostingSubscriptionId      String?             @unique
  /// Idempotency: generation pre-pay bundle (credits + free hosting) applied only once per project row.
  includesSitePurchaseBundle Boolean             @default(false)
  customDomain               String?             @unique // BYO hostname e.g. www.brand.com
  customDomainVerifiedAt     DateTime?
  domainVerificationToken    String?
  paidIterationCredits       Int                 @default(0)
  stripeAccountId            String? // connected Stripe account via Standard Connect OAuth
  paymentsEnabled            Boolean             @default(false)
  buildEnv                   Json? // { VITE_STRIPE_PUBLISHABLE_KEY: "pk_..." } — baked into build at compile time
  runtimeEnv                 String? // AES-256-GCM encrypted JSON: { STRIPE_SECRET_KEY: "sk_..." } — injected into process env only
  analyticsEvents            AnalyticsPageView[]
  emailSettings              EmailSettings?
  emailDomains               EmailDomain[]
  emailTemplates             EmailTemplate[]
  emailLogs                  EmailLog[]
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  iterationLogs              IterationLog[]
}

model IterationLog {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  title       String?
  description String?
  createdAt   DateTime @default(now())
}

model GenerationEvent {
  id        Int      @id @default(autoincrement())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  payload   Json
  createdAt DateTime @default(now())

  @@index([sessionId, id])
}

model AnalyticsPageView {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path      String   @default("/")
  device    String   @default("desktop")
  referrer  String?
  visitorId String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model EmailDomain {
  id             String          @id @default(uuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider       String          @default("resend")
  resendDomainId String          @unique
  domain         String
  dnsRecords     Json?
  verified       Boolean         @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  settings       EmailSettings[]

  @@unique([projectId, domain])
  @@index([projectId, verified])
}

model EmailSettings {
  id        String  @id @default(uuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider  String  @default("resend")

  fromName  String?
  fromEmail String

  domainId String?
  domain   EmailDomain? @relation(fields: [domainId], references: [id], onDelete: SetNull)

  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([domainId])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventType String
  subject   String
  htmlBody  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, eventType])
  @@index([projectId, eventType])
}

model EmailLog {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  provider        String  @default("resend")
  resendMessageId String?

  to      String
  from    String
  subject String
  status  String  @default("queued") // queued | sent | failed | delivered | bounced | complained | opened
  error   String?

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([projectId, createdAt])
  @@index([resendMessageId])
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model TokenUsageLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  provider     String // "anthropic" | "openai"
  model        String
  endpoint     String // "iterate.codegen" | "iterate.refine" | "iterate.repair" | "iterate.clarify" | "iterate.clarify.explore"
  inputTokens  Int
  outputTokens Int
  /// USD cost × 10_000 at log time for margin analytics (0.01¢ precision). Kept internal — users see % only.
  costMicros   Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model TokenGrant {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens          Int
  /// "migration" | "admin_grant" | "topup_purchase"
  reason          String
  /// adminUserId when reason = admin_grant
  grantedBy       String?
  stripeSessionId String?   @unique
  note            String?
  createdAt       DateTime  @default(now())
  /// null = never expires
  expiresAt       DateTime?

  @@index([userId, expiresAt])
  @@index([userId, createdAt])
}

model SupportTicket {
  id           String   @id @default(uuid())
  userId       String?
  userEmail    String
  name         String
  contactEmail String
  contactPhone String
  description  String
  status       String   @default("open") // "open" | "resolved"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}
