FROM node:20-alpine
# Match production image: generated-app install/build use pnpm (runner.ts execFileSync('pnpm', …))
RUN corepack enable && corepack prepare pnpm@latest --activate
RUN apk add --no-cache python3 make g++
RUN npm install -g pm2
WORKDIR /app
COPY package.json ./
RUN npm install
EXPOSE 4001
CMD ["npx", "tsx", "watch", "src/index.ts"]
