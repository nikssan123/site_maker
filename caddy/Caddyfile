{
    # Disable auto-HTTPS for local development
    # Remove this block in production
    auto_https off

    order rate_limit before basicauth

    servers {
        timeouts {
            read_body   30s
            read_header 10s
            write       300s
            idle        120s
        }
    }
}

# ─── Shared snippet: security headers ───────────────────────
(security_headers) {
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options        "SAMEORIGIN"
        Referrer-Policy        "strict-origin-when-cross-origin"
        -Server
    }
}

# ─── Shared snippet: proxy defaults ─────────────────────────
(proxy_defaults) {
    header_up X-Real-IP {remote_host}
}

# ─── Shared snippet: block common vulnerability scanners ────
(block_scanners) {
    @scanner_probes {
        path /.env /.env.* *.env /env.json /env.js /__env.js /__env.json
        path /stripe.* /stripe_* /*/stripe.* /*/stripe_*
        path /wp-* /wp-admin/* /wp-content/* /wp-json/* /wp-includes/*
        path /wp-config /wp-config.* /wordpress/* /xmlrpc.php
        path /.git /.git/* /.svn /.svn/* /.hg /.hg/*
        path /.vscode /.vscode/* /.idea /.idea/*
        path /.circleci /.circleci/* /.bitbucket /.bitbucket/*
        path /.travis.yml /.gitlab-ci.yml /.github/* /.gitconfig
        path /.aws /.aws/* /aws/credentials /aws-secret.* /aws-config.*
        path /.docker /.docker/* /docker-compose.* /Dockerfile*
        path /secrets /secrets.* /secrets/* /credentials /credentials.*
        path /config.inc /config.yml /config.yaml /config.json /config.js /config.ts /config.py /config.old /config.bak
        path /config/stripe.* /config/secrets.* /config/credentials.* /config/parameters.yml
        path /config/database.yml /config/application.yml /config/initializers/* /config/settings.*
        path /app/config/* /backend/config/* /instance/config.py /settings.py
        path /parameters.yml /application.yml /application.properties /appsettings.*
        path /serverless.* /swagger.json /asset-manifest.json /webhooks/settings.json
        path /info.php /phpinfo.php /phpinfo /test.php /*.php
        path /_profiler /_profiler/* /horizon/* /manage/env /server-info /server-status
        path /debug /debug/* /admin/config /admin/settings
        path /storage/* /settings/stripe.* /backup/stripe.*
        path /.vite /.vite/* /main.js /bundle.js /vendor.js /app.js /constants.js /index.js
        path /phpmyadmin /phpmyadmin/*
    }
    handle @scanner_probes {
        abort
    }
}

# ─── Shared snippet: main site routing ──────────────────────
(main_site) {
    import security_headers
    import block_scanners

    request_body {
        max_size 10MB
    }

    # Auth endpoints — strict per-IP rate limit (brute-force / spam shield)
    handle /api/auth/* {
        rate_limit {
            zone auth_per_ip {
                key    {remote_host}
                events 15
                window 1m
            }
        }
        encode zstd gzip
        reverse_proxy backend:4000 {
            import proxy_defaults
        }
    }

    # AI endpoints — streaming SSE, no compression (gzip buffers SSE chunks)
    @ai path /api/generate* /api/iterate*
    handle @ai {
        rate_limit {
            zone ai_per_ip {
                key    {remote_host}
                events 20
                window 1m
            }
        }
        reverse_proxy backend:4000 {
            import proxy_defaults
            transport http {
                read_timeout 300s
            }
            flush_interval -1
        }
    }

    # Chat endpoint — also SSE streaming
    handle /api/chat/* {
        rate_limit {
            zone chat_per_ip {
                key    {remote_host}
                events 60
                window 1m
            }
        }
        reverse_proxy backend:4000 {
            import proxy_defaults
            transport http {
                read_timeout 300s
            }
            flush_interval -1
        }
    }

    # General API (with compression)
    handle /api/* {
        rate_limit {
            zone api_per_ip {
                key    {remote_host}
                events 300
                window 1m
            }
        }
        encode zstd gzip
        reverse_proxy backend:4000 {
            import proxy_defaults
        }
    }

    # /preview-app/<id> without trailing slash → add it
    @preview_no_slash path_regexp preview_re ^/preview-app/([^/]+)$
    redir @preview_no_slash /preview-app/{re.preview_re.1}/ 308

    # Preview proxy: /preview-app/* → app-runner /preview/*
    handle_path /preview-app/* {
        encode zstd gzip
        rewrite * /preview{uri}
        reverse_proxy app-runner:4001 {
            import proxy_defaults
            transport http {
                read_timeout  300s
                dial_timeout  300s
            }
            flush_interval -1
        }
    }

    # Frontend SPA (default)
    handle {
        encode zstd gzip
        reverse_proxy frontend:5173 {
            import proxy_defaults
        }
    }
}

# ─── Main site (local dev on HTTP) ──────────────────────────
:80 {
    import main_site
}

# ─── Wildcard subdomains: local dev (lvh.me → 127.0.0.1) ───
http://*.sites.lvh.me {
    @valid_uuid header_regexp Host uuid ^([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})\.sites\.lvh\.me$

    handle @valid_uuid {
        rewrite * /preview/{re.uuid.1}{uri}
        reverse_proxy app-runner:4001 {
            import proxy_defaults
        }
    }

    handle {
        # Non-UUID subdomains (e.g. test.sites.lvh.me) resolve via /hosted/
        rewrite * /hosted{uri}
        reverse_proxy app-runner:4001 {
            header_up X-Forwarded-Host {host}
            import proxy_defaults
        }
    }
}
